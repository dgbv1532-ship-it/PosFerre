# ============================================
# API Environment Variables
# ============================================

# Database
DATABASE_URL="postgresql://pos_user:pos_password@localhost:5432/ferreteria_pos"

# JWT Secrets (generate with: openssl rand -hex 32)
JWT_ACCESS_SECRET="change_me_access_secret_32chars_min"
JWT_REFRESH_SECRET="change_me_refresh_secret_32chars_min"

# Server
PORT=3001
NODE_ENV=development
API_URL=http://localhost:3001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# ============================================
# Web Environment Variables
# ============================================

VITE_API_URL=http://localhost:3001
VITE_APP_NAME="FerretPOS"
